<section class="section-tight section-alt">
  <div class="container">
    <div class="grid grid-3">
      <div class="reveal">
        <h4>{{ check("icon-check") }} Not a copy-paste template</h4>
        <p class="text-muted mb-0">Every prompt is designed to pull out your story — not hand you someone else's words.</p>
      </div>
      <div class="reveal reveal-delay-1">
        <h4>{{ check("icon-check") }} Built for non-writers</h4>
        <p class="text-muted mb-0">No writing background required. Just honest answers to thoughtful questions.</p>
      </div>
      <div class="reveal reveal-delay-2">
        <h4>{{ check("icon-check") }} Works for any couple</h4>
        <p class="text-muted mb-0">Any tone, any tradition, any relationship — the structure adapts to you.</p>
      </div>
    </div>
  </div>
</section>

<section class="section" id="inside">
  <div class="container">
    <div class="section-header center reveal">
      <span class="eyebrow" style="justify-content:center;">What's Inside</span>
      <h2>Fourteen sections, one calm process.</h2>
      <p class="lede" style="margin-inline:auto;">
        Work through it in order, or jump to whatever you're stuck on. Either way, it's built to
        meet you where you are.
      </p>
    </div>
    <div class="grid grid-3">
      {% set sections = [
        { n: "01", title: "Finding Your Story", desc: "Prompts to uncover the memories worth building your vows around." },
        { n: "02", title: "Brainstorming Prompts", desc: "Get words on the page before you worry about getting them right." },
        { n: "03", title: "Choosing Your Tone", desc: "Playful, solemn, or somewhere in between — decide before you draft." },
        { n: "04", title: "Favorite Memories", desc: "A structured worksheet for the moments you keep coming back to." },
        { n: "05", title: "Meaningful Promises", desc: "Move past 'I promise to always...' into promises you'll actually keep." },
        { n: "06", title: "Finding Your Voice", desc: "How to tell if a line sounds like you — or like a greeting card." },
        { n: "07", title: "Editing Checklist", desc: "A simple pass to tighten your draft without losing its warmth." },
        { n: "08", title: "Common Mistakes", desc: "The five things that make vows feel borrowed instead of personal." },
        { n: "09", title: "Reading Time Guide", desc: "How to estimate your speaking length before the big day." },
        { n: "10", title: "Practice Techniques", desc: "How to rehearse without sounding rehearsed." },
        { n: "11", title: "Confidence Tips", desc: "Practical ways to steady your nerves in the minutes before you speak." },
        { n: "12", title: "Printable Worksheets", desc: "Every prompt, ready to fill in by hand if that's how you think best." },
        { n: "13", title: "Reflection Pages", desc: "Space to sit with your answers before turning them into vows." },
        { n: "14", title: "Revision Checklist", desc: "A final read-through, line by line, before you say it out loud." }
      ] %}
      {% for s in sections %}
      <div class="card reveal reveal-delay-{{ loop.index0 % 4 + 1 }}">
        <span class="badge">{{ s.n }}</span>
        <h3 style="margin-top: 0.75rem;">{{ s.title }}</h3>
        <p class="text-muted mb-0">{{ s.desc }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section section-alt">
  <div class="container">
    <div class="two-col reverse">
      <div class="reveal">
        <div class="preview-gallery">
          <div class="preview-page">
            <span class="badge">08 &middot; Common Mistakes</span>
            <div class="preview-line" style="margin-top:1rem;"></div>
            <div class="preview-line short"></div>
            <div class="preview-line"></div>
            <div class="preview-line short"></div>
            <span class="preview-page-label">Checklist: Five phrases to reconsider</span>
          </div>
          <div class="preview-page">
            <span class="badge">14 &middot; Revision Checklist</span>
            <div class="preview-line" style="margin-top:1rem;"></div>
