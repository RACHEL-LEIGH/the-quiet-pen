{# Shared inline SVG icons — kept as macros so markup stays semantic and dependency-free.
   Every icon (except the large decorative illustration) gets the base "icon"
   class so it always has a sane default size even if a caller passes none. #}

{% macro brandMark(class="brand-mark") %}
<svg class="icon {{ class }}" viewBox="0 0 32 32" fill="none" aria-hidden="true">
  <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.2" opacity="0.35" />
  <path d="M10 22 L21 9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
  <path d="M19 8.2c1.1-1.1 2.9-1.1 4 0 1.1 1.1 1.1 2.9 0 4L11.6 24.6l-4 1 1-4L19 8.2Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" />
</svg>
{% endmacro %}

{% macro check(class="") %}
<svg class="icon {{ class }}" viewBox="0 0 20 20" fill="none" aria-hidden="true">
  <path d="M4 10.5l3.5 3.5L16 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
</svg>
{% endmacro %}

